{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "matchPackageNames": ["node"],
      "allowedVersions": "^24.0.0"
    }
  ],
  "mise": {
    "enabled": true,
    "fileMatch": ["^mise\\.toml$", "^\\.config/mise/config\\.toml$"]
  }
}
