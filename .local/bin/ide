#!/bin/bash

if [[ -n "$1" ]]; then
    selected=$(cd "$1" && pwd)
else
    selected=$(find "$HOME/workspace" -maxdepth 3 -name ".git" 2>/dev/null | xargs -n1 dirname | sort -u | fzf --prompt="Project > ")
fi

if [[ -z "$selected" ]]; then
    echo "No project selected"
    exit 0
fi

project_name=$(basename "$selected")
branch=$(cd "$selected" && git branch --show-current 2>/dev/null || echo "main")

# 1. 衝突を防ぐため、絶対パスとブランチ名からハッシュ値（先頭6文字）を生成
# macOS(md5)とLinux(md5sum)の違いを吸収します
if command -v md5sum >/dev/null 2>&1; then
    hash_val=$(echo -n "${selected}:${branch}" | md5sum | cut -c1-6)
else
    hash_val=$(echo -n "${selected}:${branch}" | md5 | cut -c1-6)
fi

# 2. セッション一覧を見たときに人間が判別するためのベース文字列
base_name="${project_name}:${branch//\//-}"

# 3. 最大24文字に収める (macOSのソケットパス104バイト制限)
# ベース文字列(17文字) + "_" + ハッシュ(6文字) = 24文字
session_name="${base_name:0:17}_${hash_val}"

if [[ -n "$ZELLIJ" ]]; then
    zellij action detach
fi

cd "$selected"
zellij attach "$session_name" 2>/dev/null || zellij -s "$session_name"
