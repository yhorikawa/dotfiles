#!/bin/bash

if [[ -n "$1" ]]; then
  selected=$(cd "$1" && pwd)
else
  selected=$(find "$HOME/workspace" -maxdepth 3 -name ".git" 2>/dev/null | xargs -n1 dirname | sort -u | fzf --prompt="Project > ")
fi

if [[ -z "$selected" ]]; then
  echo "No project selected"
  exit 0
fi

current_pane_id=$(wezterm cli list-clients --format json | jq -r '.[0].focused_pane_id' 2>/dev/null)
existing=$(wezterm cli list --format json | jq -r ".[] | select(.cwd == \"file://$selected\" and .pane_id != $current_pane_id) | .pane_id" | head -1)

if [[ -n "$existing" ]]; then
  wezterm cli activate-pane --pane-id "$existing"
else
  new_pane_id=$(wezterm cli spawn --cwd "$selected")
  right_pane_id=$(wezterm cli split-pane --pane-id "$new_pane_id" --right --percent 30 --cwd "$selected")
  bottom_left_id=$(wezterm cli split-pane --pane-id "$new_pane_id" --bottom --percent 50 --cwd "$selected")

  sleep 0.5
  wezterm cli send-text --pane-id "$new_pane_id" --no-paste $'hx .\n'
fi
